#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && cd .. && pwd)"
export DOTFILES_USE_RBENV=1
source "$ROOT/script/env" "$@"
cd "$ROOT"

fail() {
    echo "Error: $*" >&2
    exit 1
}

require_command() {
    local command_name=$1
    command -v "$command_name" >/dev/null 2>&1 || fail "required command not found: $command_name"
}

validate_jsonc() {
    local file_path=$1

    "$ROOT/script/test-check" jsonc "$file_path"
}

validate_yaml() {
    local file_path=$1

    "$ROOT/script/test-check" yaml "$file_path"
}

validate_bundler_supply_chain() {
    "$ROOT/script/test-check" bundler-supply-chain "$ROOT"
}

validate_ci_workflow_action_pins() {
    "$ROOT/script/test-check" ci-workflow-action-pins "$ROOT"
}

validate_alias_metadata() {
    local missing_metadata
    local missing_commands

    set +u
    source "$ROOT/dotfiles/.bash_aliases"
    set -u

    missing_metadata=$(
        comm -23 \
            <(_tracked_alias_commands | awk 'NF && !seen[$0]++' | sort) \
            <(_documented_alias_names "$ROOT/dotfiles/.aliases.yml" | sort)
    )
    missing_commands=$(
        comm -13 \
            <(_tracked_alias_commands | awk 'NF && !seen[$0]++' | sort) \
            <(_documented_alias_names "$ROOT/dotfiles/.aliases.yml" | sort)
    )

    if [ -n "$missing_metadata" ]; then
        printf "Tracked aliases/functions missing metadata:\n%s\n" "$missing_metadata" >&2
        return 1
    fi

    if [ -n "$missing_commands" ]; then
        printf "Documented aliases/functions not found in .bash_aliases:\n%s\n" "$missing_commands" >&2
        return 1
    fi
}

validate_vscode_fixture_plan() {
    local fixture_plan
    local fixture_user_dir

    fixture_user_dir="$(mktemp -d)"
    fixture_plan="$(
        DOTFILES_VSCODE_INSTALLED_EXTENSIONS_FILE="$ROOT/test/fixtures/vscode/installed-extensions.txt" \
            DOTFILES_VSCODE_USER_DIR="$fixture_user_dir" \
            "$ROOT/script/vscode" plan --format json
    )"
    rm -rf "$fixture_user_dir"

    "$ROOT/script/test-check" vscode-fixture-plan "$fixture_plan"
}

validate_git_secretive_policy() {
    "$ROOT/script/test-check" git-secretive-policy "$ROOT"
}

validate_public_safety() {
    "$ROOT/script/test-check" public-safety "$ROOT"
}

validate_set_secret_collision_guard() {
    bash <<'BASH'
set -euo pipefail

source "shell/functions/secrets.bash"

for candidate in var_name target_var secret_value "_dotfiles_set_secret_value_$$"; do
    unset INJECTED
    unset -v "$candidate"

    set_secret "$candidate" <<<"INJECTED=1" >/dev/null

    if [ "${INJECTED-unset}" != "unset" ]; then
        echo "set_secret exported injected assignment for $candidate" >&2
        exit 1
    fi

    if [ "${!candidate}" != "INJECTED=1" ]; then
        echo "set_secret did not assign $candidate" >&2
        exit 1
    fi

    unset INJECTED
    printf -v "$candidate" '%s' old
    export "$candidate"

    if set_secret "$candidate" < <(printf partial) >/dev/null 2>/dev/null; then
        echo "set_secret succeeded on partial input for $candidate" >&2
        exit 1
    fi

    if [ "${!candidate}" != "old" ]; then
        echo "set_secret clobbered $candidate after failed read" >&2
        exit 1
    fi

    if [ "${INJECTED-unset}" != "unset" ]; then
        echo "set_secret exported injected assignment after failed read for $candidate" >&2
        exit 1
    fi

    set_secret --confirm "$candidate" <<'INPUT' >/dev/null
matching value
matching value
INPUT

    if [ "${!candidate}" != "matching value" ]; then
        echo "set_secret --confirm did not assign matching input for $candidate" >&2
        exit 1
    fi

    printf -v "$candidate" '%s' old
    export "$candidate"

    if set_secret --confirm "$candidate" <<'INPUT' >/dev/null 2>/dev/null
first value
second value
INPUT
    then
        echo "set_secret --confirm succeeded on mismatched input for $candidate" >&2
        exit 1
    fi

    if [ "${!candidate}" != "old" ]; then
        echo "set_secret --confirm clobbered $candidate after mismatch" >&2
        exit 1
    fi

    set_secret --confirm=3 "$candidate" <<'INPUT' >/dev/null
triple value
triple value
triple value
INPUT

    if [ "${!candidate}" != "triple value" ]; then
        echo "set_secret --confirm=3 did not assign matching input for $candidate" >&2
        exit 1
    fi

    printf -v "$candidate" '%s' old
    export "$candidate"

    if set_secret --confirm=3 "$candidate" <<'INPUT' >/dev/null 2>/dev/null
triple value
triple value
mismatch
INPUT
    then
        echo "set_secret --confirm=3 succeeded on mismatched input for $candidate" >&2
        exit 1
    fi

    if [ "${!candidate}" != "old" ]; then
        echo "set_secret --confirm=3 clobbered $candidate after mismatch" >&2
        exit 1
    fi
done

if set_secret --confirm=4 invalid_count >/dev/null 2>/dev/null; then
    echo "set_secret accepted invalid confirm count" >&2
    exit 1
fi

trace_output="$({
    set -x
    set_secret --confirm trace_candidate <<'INPUT' >/dev/null
trace value
trace value
INPUT
    set +x
} 2>&1)"

case "$trace_output" in
    *"trace value"*)
        echo "set_secret leaked prompted input through xtrace" >&2
        exit 1
        ;;
esac
BASH
}

require_command bash
require_command bundle
require_command git
require_command ruby

"$ROOT/script/manifest" validate >/dev/null
ruby -c "$ROOT/lib/dotfiles/manifest.rb" >/dev/null
ruby -c "$ROOT/lib/dotfiles/vscode.rb" >/dev/null
ruby -c "$ROOT/lib/dotfiles/runtime.rb" >/dev/null
ruby -c "$ROOT/lib/dotfiles/installer.rb" >/dev/null
ruby -c "$ROOT/lib/dotfiles/restorer.rb" >/dev/null
ruby -c "$ROOT/lib/dotfiles/socket_firewall.rb" >/dev/null
ruby -c "$ROOT/lib/dotfiles/sfw_binary.rb" >/dev/null
ruby -c "$ROOT/lib/dotfiles/doctor.rb" >/dev/null
ruby -c "$ROOT/lib/dotfiles/vendor.rb" >/dev/null
ruby -c "$ROOT/lib/dotfiles/test_checks.rb" >/dev/null
ruby -c "$ROOT/lib/dotfiles/vsc_extension_wrapper.rb" >/dev/null
ruby -c "$ROOT/script/manifest" >/dev/null
ruby -c "$ROOT/script/vscode" >/dev/null
ruby -c "$ROOT/script/install" >/dev/null
ruby -c "$ROOT/script/restore" >/dev/null
ruby -c "$ROOT/script/doctor" >/dev/null
ruby -c "$ROOT/script/socket-firewall" >/dev/null
ruby -c "$ROOT/script/vendor" >/dev/null
ruby -c "$ROOT/script/test-check" >/dev/null
ruby -c "$ROOT/script/vsc-extension-bulk-install" >/dev/null
"$ROOT/script/vscode" validate >/dev/null
"$ROOT/script/vscode" plan >/dev/null
"$ROOT/script/vsc-extension-bulk-install" --dry-run >/dev/null
validate_vscode_fixture_plan
validate_git_secretive_policy
validate_public_safety
validate_bundler_supply_chain
validate_ci_workflow_action_pins
bundle exec rspec spec

shell_files=(
    "script/bootstrap"
    "script/env"
    "script/test"
    "dotfiles/.bash_aliases"
    "dotfiles/.bash_logout"
    "dotfiles/.bashrc"
    "dotfiles/.profile"
)

while IFS= read -r shell_file; do
    shell_files+=("$shell_file")
done < <(find shell -type f -name '*.bash' -print | sort)

while IFS= read -r shell_file; do
    shell_files+=("$shell_file")
done < <(find local-bin -type f -print | sort)

for shell_file in "${shell_files[@]}"; do
    bash -n "$shell_file"
done

validate_set_secret_collision_guard

json_files=(
    "configs/karabiner/karabiner.json"
    "configs/vsc/keybindings.json"
    "configs/vsc/settings.json"
    "configs/vsc/tasks.json"
)

for json_file in "${json_files[@]}"; do
    validate_jsonc "$json_file"
done

while IFS= read -r snippet_file; do
    validate_jsonc "$snippet_file"
done < <(find configs/vsc/snippets -type f -name '*.json' -print | sort)

while IFS= read -r yaml_file; do
    validate_yaml "$yaml_file"
done < <(find . -path './.git' -prune -o \( -name '*.yml' -o -name '*.yaml' \) -print | sed 's#^\./##' | sort)

validate_alias_metadata

dead_paths=(
    "configs/vsc/linux"
    "configs/vsc/mac"
    "configs/alacritty/old_alacritty.yml"
    "configs/alacritty/alacritty_mac.toml"
    "dotfiles/.gitconfig_mac"
    "dotfiles/.gitconfig_linux"
    "dotfiles/linux_server"
)

for dead_path in "${dead_paths[@]}"; do
    if [ -f "$dead_path" ]; then
        fail "dead file still exists: $dead_path"
    fi

    if [ -d "$dead_path" ] && [ -n "$(find "$dead_path" -type f -print -quit)" ]; then
        fail "dead directory still contains files: $dead_path"
    fi
done

dead_marker_pattern="linux_server|gitconfig_linux|linuxbrew|crystal|crenv|notify-send|dircolors|/home/grantbirki|/mnt/c"
if command -v rg >/dev/null 2>&1; then
    if rg -n -i "$dead_marker_pattern" \
        --hidden \
        --glob '!.git/**' \
        --glob '!script/test' \
        "$ROOT"; then
        fail "dead Linux-era marker found"
    fi
else
    dead_marker_found=0
    while IFS= read -r scanned_file; do
        if grep -n -I -i -E "$dead_marker_pattern" "$scanned_file"; then
            dead_marker_found=1
        fi
    done < <(find "$ROOT" -path "$ROOT/.git" -prune -o -type f ! -path "$ROOT/script/test" -print)

    if [ "$dead_marker_found" -eq 1 ]; then
        fail "dead Linux-era marker found"
    fi
fi

echo "All checks passed."
