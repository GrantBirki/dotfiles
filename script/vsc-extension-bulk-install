#!/usr/bin/env bash

# Compatibility wrapper for the VS Code desired-state manager.

set -euo pipefail
IFS=$'\n\t'

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && cd .. && pwd)"
dry_run=0
prune=1
extensions_path=""

usage() {
	cat <<'USAGE'
Usage: script/vsc-extension-bulk-install [--dry-run] [--no-prune] [path/to/extensions.yml]

Compatibility wrapper around `script/vscode`.
USAGE
}

while [ "$#" -gt 0 ]; do
	case "$1" in
		--dry-run|-n)
			dry_run=1
			shift
			;;
		--no-prune)
			prune=0
			shift
			;;
		--help|-h)
			usage
			exit 0
			;;
		-*)
			echo "Unknown option: $1" >&2
			usage >&2
			exit 2
			;;
		*)
			extensions_path=$1
			shift
			if [ "$#" -gt 0 ]; then
				echo "Only one extension manifest path may be provided." >&2
				usage >&2
				exit 2
			fi
			;;
	esac
done

args=()
if [ "$dry_run" -eq 1 ]; then
	args+=("plan")
else
	args+=("apply")
fi

if [ "$prune" -eq 0 ]; then
	args+=("--no-prune")
fi

if [ -n "$extensions_path" ]; then
	args+=("--extensions" "$extensions_path")
fi

"$DIR/script/vscode" "${args[@]}"
