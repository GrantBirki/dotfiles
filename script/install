#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && cd .. && pwd)"
source "$DIR/script/env" "$@"

dry_run=0

usage() {
    cat <<'USAGE'
Usage: script/install [--dry-run]

Install managed dotfiles from install.yml.
USAGE
}

timestamp() {
    date "+%Y%m%d%H%M%S"
}

unique_path() {
    local path=$1
    local base
    local candidate
    local counter=1

    if [ ! -e "$path" ] && [ ! -L "$path" ]; then
        printf "%s\n" "$path"
        return 0
    fi

    base="$path.$(timestamp)"
    candidate="$base"
    while [ -e "$candidate" ] || [ -L "$candidate" ]; do
        candidate="$base.$counter"
        counter=$((counter + 1))
    done

    printf "%s\n" "$candidate"
}

record_state() {
    local id=$1
    local source_path=$2
    local target_path=$3
    local backup_path=$4
    local action=$5

    if [ "$dry_run" -eq 0 ]; then
        printf "%s\t%s\t%s\t%s\t%s\n" "$id" "$source_path" "$target_path" "$backup_path" "$action" >> "$state_tmp"
    fi
}

for arg in "$@"; do
    case "$arg" in
        --dry-run|-n)
            dry_run=1
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --production)
            ;;
        *)
            echo "Unknown option: $arg" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [[ "$OSTYPE" != "darwin"* ]]; then
    echo "This dotfiles installer only supports macOS." >&2
    exit 1
fi

"$DIR/script/manifest" validate >/dev/null

state_dir="$DIR/.dotfiles/state"
state_file="$(unique_path "$state_dir/install-$(timestamp).tsv")"
state_tmp="$state_file.tmp"

if [ "$dry_run" -eq 0 ]; then
    mkdir -p "$state_dir"
    printf "id\tsource_path\ttarget_path\tbackup_path\taction\n" > "$state_tmp"
    trap 'rm -f "$state_tmp"' EXIT
else
    echo "Dry run: no filesystem changes will be made."
fi

mkdir_args=("$HOME/.cargo" "$HOME/.local/bin")
for dir_path in "${mkdir_args[@]}"; do
    if [ "$dry_run" -eq 1 ]; then
        echo "Would ensure directory exists: $dir_path"
    else
        mkdir -p "$dir_path"
    fi
done

while IFS=$'\t' read -r id source_path target_path backup_path target_parent parent_policy mode; do
    if [ "$mode" != "symlink" ]; then
        echo "Unsupported install mode for $id: $mode" >&2
        exit 1
    fi

    if [ "$parent_policy" = "require" ] && [ ! -d "$target_parent" ]; then
        echo "Skipping $id because parent directory is missing: $target_parent"
        record_state "$id" "$source_path" "$target_path" "" "skipped-parent"
        continue
    fi

    if [ "$parent_policy" = "create" ]; then
        if [ "$dry_run" -eq 1 ]; then
            echo "Would ensure parent directory exists: $target_parent"
        else
            mkdir -p "$target_parent"
        fi
    fi

    if [ -L "$target_path" ] && [ "$(readlink "$target_path")" = "$source_path" ]; then
        echo "$target_path already links to $source_path"
        record_state "$id" "$source_path" "$target_path" "" "already-linked"
        continue
    fi

    actual_backup_path=""
    if [ -e "$target_path" ] || [ -L "$target_path" ]; then
        actual_backup_path="$(unique_path "$backup_path")"
        if [ "$dry_run" -eq 1 ]; then
            echo "Would move existing $target_path to $actual_backup_path"
        else
            mkdir -p "$(dirname "$actual_backup_path")"
            mv "$target_path" "$actual_backup_path"
        fi
    fi

    if [ "$dry_run" -eq 1 ]; then
        echo "Would create symlink: $target_path -> $source_path"
    else
        ln -s "$source_path" "$target_path"
    fi
    record_state "$id" "$source_path" "$target_path" "$actual_backup_path" "linked"
done < <("$DIR/script/manifest" entries)

if [ "$dry_run" -eq 0 ]; then
    mv "$state_tmp" "$state_file"
    trap - EXIT
    echo "Install state written to $state_file"
fi

echo "Make sure to run 'source ~/.bashrc' to finish applying shell changes."
echo "Done."
