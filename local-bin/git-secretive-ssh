#!/usr/bin/env bash

set -euo pipefail

secretive_socket="${SECRETIVE_SSH_AUTH_SOCK:-$HOME/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/socket.ssh}"
identity_file="${GIT_SECRETIVE_IDENTITY_FILE:-$HOME/.config/git/secretive_git_key.pub}"
ssh_bin="${GIT_SECRETIVE_SSH_BIN:-/usr/bin/ssh}"

if [ "${GIT_SECRETIVE_TEST_SKIP_SOCKET_CHECK:-}" != "1" ] && [ ! -S "$secretive_socket" ]; then
    echo "Secretive SSH agent socket is not available: $secretive_socket" >&2
    exit 255
fi

if [ ! -r "$identity_file" ]; then
    echo "Secretive Git public identity is not readable: $identity_file" >&2
    exit 255
fi

export SSH_AUTH_SOCK="$secretive_socket"

exec "$ssh_bin" \
    -o "IdentityAgent=$secretive_socket" \
    -o "IdentitiesOnly=yes" \
    -o "IdentityFile=$identity_file" \
    -o "PreferredAuthentications=publickey" \
    -o "PubkeyAuthentication=yes" \
    -o "PasswordAuthentication=no" \
    -o "KbdInteractiveAuthentication=no" \
    -o "ChallengeResponseAuthentication=no" \
    -o "BatchMode=yes" \
    -o "AddKeysToAgent=no" \
    -o "UseKeychain=no" \
    "$@"
