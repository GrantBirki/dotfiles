#!/usr/bin/env bash

set -euo pipefail

secretive_socket="${SECRETIVE_SSH_AUTH_SOCK:-$HOME/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/socket.ssh}"
identity_file="${GIT_SECRETIVE_IDENTITY_FILE:-$HOME/.config/git/secretive_git_key.pub}"
ssh_keygen_bin="${GIT_SECRETIVE_SSH_KEYGEN_BIN:-/usr/bin/ssh-keygen}"

expand_home() {
    case "$1" in
        "~/"*) printf "%s/%s\n" "$HOME" "${1#~/}" ;;
        *) printf "%s\n" "$1" ;;
    esac
}

is_sign_command=0
signing_file=""
previous_arg=""

for arg in "$@"; do
    if [ "$previous_arg" = "-Y" ] && [ "$arg" = "sign" ]; then
        is_sign_command=1
    fi

    if [ "$previous_arg" = "-f" ]; then
        signing_file="$arg"
        previous_arg=""
        continue
    fi

    case "$arg" in
        -f?*) signing_file="${arg#-f}" ;;
    esac

    previous_arg="$arg"
done

if [ "$is_sign_command" -eq 1 ]; then
    if [ "${GIT_SECRETIVE_TEST_SKIP_SOCKET_CHECK:-}" != "1" ] && [ ! -S "$secretive_socket" ]; then
        echo "Secretive SSH agent socket is not available: $secretive_socket" >&2
        exit 255
    fi

    expected_file="$(expand_home "$identity_file")"
    actual_file="$(expand_home "$signing_file")"

    if [ -z "$signing_file" ]; then
        echo "Git SSH signing did not provide a signing key file." >&2
        exit 255
    fi

    if [ "$actual_file" != "$expected_file" ]; then
        echo "Refusing Git SSH signing with non-Secretive key: $signing_file" >&2
        exit 255
    fi

    if [ ! -r "$expected_file" ]; then
        echo "Secretive Git public signing key is not readable: $expected_file" >&2
        exit 255
    fi
fi

if [ "$is_sign_command" -eq 1 ]; then
    export SSH_AUTH_SOCK="$secretive_socket"
fi
exec "$ssh_keygen_bin" "$@"
